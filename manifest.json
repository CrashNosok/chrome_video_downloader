{
  "manifest_version": 3,
  "name": "Kinescope + Telegram + Instagram Video Downloader",
  "version": "1.2.0",
  "description": "Download videos from Kinescope embeds, Telegram Web (WebK), and Instagram (reels/posts)",
  "permissions": [
    "activeTab",
    "downloads",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://kinescope.io/*",
    "https://web.telegram.org/*",
    "https://www.instagram.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://kinescope.io/embed/*"],
      "js": ["kinescope-player.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://web.telegram.org/*"],
      "js": ["telegram.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["instagram.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
